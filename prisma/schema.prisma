// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Category {
  MASCULINO
  FEMENINO
}

enum Phase {
  GRUPOS
  CUARTOS
  SEMIFINAL
  FINAL
}

enum MatchStatus {
  PROGRAMADO
  EN_JUEGO
  FINALIZADO
}

enum EventType {
  GOL
  AMARILLA
  ROJA
}

enum SanctionType {
  W_2MIN        // hasta 2 min tarde: un jugador menos
  W_4MIN        // hasta 4 min tarde: 2 jugadores menos y 0-1 en contra
  W_6MIN        // hasta 6 min tarde: partido perdido 3-0
  INASISTENCIA  // no vino al torneo: +3 pts y +3 goles a los demás del grupo
}

model Team {
  id        Int      @id @default(autoincrement())
  name      String
  category  Category
  createdAt DateTime @default(now())

  group     Group?   @relation(fields: [groupId], references: [id])
  groupId   Int?

  players   Player[]

  matchesAsTeamA Match[] @relation("MatchesAsTeamA")
  matchesAsTeamB Match[] @relation("MatchesAsTeamB")

  events    MatchEvent[]
  sanctions Sanction[]   // 👈 NUEVO: sanciones de este equipo
}

model Player {
  id        Int      @id @default(autoincrement())
  name      String
  number    Int?
  createdAt DateTime @default(now())

  team      Team     @relation(fields: [teamId], references: [id])
  teamId    Int

  events    MatchEvent[]
}

model Group {
  id          Int    @id @default(autoincrement())
  name        String
  fieldNumber Int

  teams       Team[]
}

model Match {
  id          Int         @id @default(autoincrement())
  phase       Phase
  status      MatchStatus @default(PROGRAMADO)
  fieldNumber Int
  scheduledAt DateTime
  createdAt   DateTime    @default(now())

  teamA   Team @relation("MatchesAsTeamA", fields: [teamAId], references: [id])
  teamAId Int
  teamB   Team @relation("MatchesAsTeamB", fields: [teamBId], references: [id])
  teamBId Int

  scoreA Int?
  scoreB Int?

  events    MatchEvent[]
  sanctions Sanction[]   // 👈 NUEVO: sanciones aplicadas en este partido
}

model MatchEvent {
  id        Int       @id @default(autoincrement())
  type      EventType
  minute    Int?
  createdAt DateTime  @default(now())

  match    Match   @relation(fields: [matchId], references: [id])
  matchId  Int
  team     Team    @relation(fields: [teamId], references: [id])
  teamId   Int
  player   Player? @relation(fields: [playerId], references: [id])
  playerId Int?
}

model Sanction {
  id        Int          @id @default(autoincrement())
  type      SanctionType
  note      String?      // observación del supervisor
  createdAt DateTime     @default(now())

  team    Team   @relation(fields: [teamId], references: [id])
  teamId  Int
  match   Match? @relation(fields: [matchId], references: [id]) // opcional: INASISTENCIA no pertenece a un partido
  matchId Int?
}