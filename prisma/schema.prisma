// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Category {
  MASCULINO
  FEMENINO
}

enum Phase {
  GRUPOS
  CUARTOS
  SEMIFINAL
  FINAL
}

enum MatchStatus {
  PROGRAMADO
  EN_JUEGO
  FINALIZADO
}

model Team {
  id        Int      @id @default(autoincrement())
  name      String
  category  Category
  createdAt DateTime @default(now())

  group     Group?   @relation(fields: [groupId], references: [id])
  groupId   Int?

  players   Player[]

  matchesAsTeamA Match[] @relation("MatchesAsTeamA") // 👈 partidos donde este equipo es el A
  matchesAsTeamB Match[] @relation("MatchesAsTeamB") // 👈 partidos donde es el B
}

model Player {
  id        Int      @id @default(autoincrement())
  name      String
  number    Int?
  createdAt DateTime @default(now())

  team      Team     @relation(fields: [teamId], references: [id])
  teamId    Int
}

model Group {
  id          Int    @id @default(autoincrement())
  name        String
  fieldNumber Int

  teams       Team[]
}

model Match {
  id          Int         @id @default(autoincrement())
  phase       Phase       // GRUPOS, CUARTOS, SEMIFINAL o FINAL
  status      MatchStatus @default(PROGRAMADO) // nace "programado" automáticamente
  fieldNumber Int         // cancha 1-4
  scheduledAt DateTime    // fecha y hora del partido
  createdAt   DateTime    @default(now())

  teamA   Team @relation("MatchesAsTeamA", fields: [teamAId], references: [id]) // 👈 hilo con nombre
  teamAId Int
  teamB   Team @relation("MatchesAsTeamB", fields: [teamBId], references: [id]) // 👈 el otro hilo
  teamBId Int

  scoreA Int? // vacío = no se ha jugado (≠ 0)
  scoreB Int?
}