// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Category {
  MASCULINO
  FEMENINO
}

enum Phase {
  GRUPOS
  CUARTOS
  SEMIFINAL
  FINAL
}

enum MatchStatus {
  PROGRAMADO
  EN_JUEGO
  FINALIZADO
}

enum EventType {
  GOL
  AMARILLA
  ROJA
}

model Team {
  id        Int      @id @default(autoincrement())
  name      String
  category  Category
  createdAt DateTime @default(now())

  group     Group?   @relation(fields: [groupId], references: [id])
  groupId   Int?

  players   Player[]

  matchesAsTeamA Match[] @relation("MatchesAsTeamA")
  matchesAsTeamB Match[] @relation("MatchesAsTeamB")

  events    MatchEvent[] // eventos de este equipo (goles, tarjetas)
}

model Player {
  id        Int      @id @default(autoincrement())
  name      String
  number    Int?
  createdAt DateTime @default(now())

  team      Team     @relation(fields: [teamId], references: [id])
  teamId    Int

  events    MatchEvent[] // eventos de este jugador
}

model Group {
  id          Int    @id @default(autoincrement())
  name        String
  fieldNumber Int

  teams       Team[]
}

model Match {
  id          Int         @id @default(autoincrement())
  phase       Phase
  status      MatchStatus @default(PROGRAMADO)
  fieldNumber Int
  scheduledAt DateTime
  createdAt   DateTime    @default(now())

  teamA   Team @relation("MatchesAsTeamA", fields: [teamAId], references: [id])
  teamAId Int
  teamB   Team @relation("MatchesAsTeamB", fields: [teamBId], references: [id])
  teamBId Int

  scoreA Int?
  scoreB Int?

  events MatchEvent[] // el "acta": todo lo que pasó en este partido
}

model MatchEvent {
  id        Int       @id @default(autoincrement())
  type      EventType // GOL, AMARILLA o ROJA
  minute    Int?      // minuto del partido (opcional)
  createdAt DateTime  @default(now())

  match    Match   @relation(fields: [matchId], references: [id]) // 👈 hilo 1: el partido
  matchId  Int
  team     Team    @relation(fields: [teamId], references: [id])  // 👈 hilo 2: el equipo
  teamId   Int
  player   Player? @relation(fields: [playerId], references: [id]) // 👈 hilo 3: el jugador (opcional)
  playerId Int?
}